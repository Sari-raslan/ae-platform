{
  "name": "universal-arranger-os",
  "version": "1.0.0",
  "main": "electron/main.cjs",
  "scripts": {
    "desktop:start": "electron electron/main.cjs",
    "frontend:build": "cd frontend && npm run build",
    "desktop:build": "cd frontend && npm run build && electron-builder",
    "release:win": "cd frontend && npm run build && electron-builder --win nsis portable"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.universalarranger.os",
    "productName": "Universal Arranger OS",
    "directories": { "output": "release" },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "package.json"
    ],
    "win": { "target": ["nsis", "portable"] },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Universal Arranger OS"
    }
  }
}
